{
  "title": "subworkflow - aws create resource tags",
  "description": "Subworkflow to add tags to AWS resources\n\nParameters:\n\nresourceIds: (Required) Comma-separated resource IDs to tag\ntagsJson: (Required) JSON object with tags {key: value}\nawsregion: (Required) AWS region\ndynatraceawsconnection: (Required) AWS OIDC connection\n\nApplies tags to resources",
  "ownerType": "USER",
  "isPrivate": false,
  "schemaVersion": 3,
  "trigger": {},
  "result": "{{ result(\"check-status\") }}",
  "type": "STANDARD",
  "input": {"resourceIds": "i-1234567890abcdef0", "tagsJson": "{\"Environment\": \"Production\", \"CostCenter\": \"Engineering\"}", "awsregion": "us-east-1", "dynatraceawsconnection": "awsplayground"},
  "hourlyExecutionLimit": 1000,
  "guide": "## 🏷️ **Create Resource Tags**\n\nAdds tags to AWS resources via SSM.",
  "tasks": {
    "check-status": {
      "name": "check-status",
      "input": {"script": "import { execution } from '@dynatrace-sdk/automation-utils';\nexport default async function ({ execution_id }) {\n  const configGet = await fetch(`/platform/automation/v1/executions/${execution_id}/tasks/wait-for-completion/result`);\n  const configBody = await configGet.json();\n  if (configBody.AutomationExecutionStatus !== \"Success\") throw new Error(\"Tagging failed!\");\n  return configBody;\n}"},
      "action": "dynatrace.automations:run-javascript",
      "timeout": 30,
      "position": {"x": 0, "y": 3},
      "conditions": {"states": {"wait-for-completion": "OK"}},
      "predecessors": ["wait-for-completion"]
    },
    "wait-for-completion": {
      "name": "wait-for-completion",
      "input": {"workflowId": "20661ec0-29d5-471f-9973-29679d5fe908", "workflowInput": "{\n  \"AutomationExecutionId\": \"{{ result(\"start-automation\").AutomationExecutionId }}\",\n  \"awsregion\": \"{{ input()[\"awsregion\"] }}\",\n  \"dynatraceawsconnection\": \"{{ input()[\"dynatraceawsconnection\"] }}\"\n}"},
      "retry": {"count": 99, "delay": 60, "failedLoopIterationsOnly": true},
      "action": "dynatrace.automations:run-workflow",
      "timeout": 604800,
      "position": {"x": 0, "y": 2},
      "conditions": {"states": {"start-automation": "OK"}},
      "predecessors": ["start-automation"]
    },
    "start-automation": {
      "name": "start-automation",
      "input": {"region": "{{ input()[\"awsregion\"] }}", "schema": "builtin:hyperscaler-authentication.connections.aws", "Parameters": "{\n  \"ResourceIds\": [\"{{ input()[\"resourceIds\"] }}\"]\n}", "connection": "{% set awsconnection = input()[\"dynatraceawsconnection\"] %}\n{{ connection('builtin:hyperscaler-authentication.connections.aws', awsconnection) }}", "DocumentName": "AWS-CreateTags"},
      "retry": {"count": 5, "delay": 60, "failedLoopIterationsOnly": true},
      "action": "dynatrace.aws.connector:ssm-start-automation-execution",
      "timeout": 604800,
      "position": {"x": 0, "y": 1},
      "predecessors": []
    }
  }
}

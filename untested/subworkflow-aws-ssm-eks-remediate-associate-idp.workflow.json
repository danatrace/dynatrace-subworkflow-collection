{
  "title": "subworkflow - aws ssm eks remediate associate idp",
  "description": "Remediation subworkflow to associate an EKS identity provider config",
  "ownerType": "USER",
  "isPrivate": false,
  "schemaVersion": 3,
  "trigger": {},
  "result": "{{ result(\"check-status\") }}",
  "type": "STANDARD",
  "input": {
    "clusterName": "example-eks-cluster",
    "oidcIssuerUrl": "https://issuer.example.com",
    "clientId": "sts.amazonaws.com",
    "awsregion": "us-east-1",
    "dynatraceawsconnection": "awsplayground"
  },
  "hourlyExecutionLimit": 1000,
  "guide": "Remediation workflow that uses AWS-ExecuteAwsApi to call eks:AssociateIdentityProviderConfig.",
  "tasks": {
    "check-status": {
      "name": "check-status",
      "input": {
        "script": "export default async function ({ execution_id }) {\\n  const r = await fetch(`/platform/automation/v1/executions/${execution_id}/tasks/wait-for-completion/result`).then(d => d.json());\\n  if (r.AutomationExecutionStatus !== \\\"Success\\\") throw new Error(\\\"Associate identity provider config failed\\\");\\n  return r;\\n}"
      },
      "action": "dynatrace.automations:run-javascript",
      "timeout": 30,
      "position": {
        "x": 0,
        "y": 3
      },
      "conditions": {
        "states": {
          "wait-for-completion": "OK"
        }
      },
      "predecessors": [
        "wait-for-completion"
      ]
    },
    "wait-for-completion": {
      "name": "wait-for-completion",
      "input": {
        "workflowId": "20661ec0-29d5-471f-9973-29679d5fe908",
        "workflowInput": "{\n  \"AutomationExecutionId\": \"{{ result(\"start-automation\").AutomationExecutionId }}\",\n  \"awsregion\": \"{{ input()[\"awsregion\"] }}\",\n  \"dynatraceawsconnection\": \"{{ input()[\"dynatraceawsconnection\"] }}\"\n}"
      },
      "retry": {
        "count": 99,
        "delay": 60,
        "failedLoopIterationsOnly": true
      },
      "action": "dynatrace.automations:run-workflow",
      "timeout": 604800,
      "position": {
        "x": 0,
        "y": 2
      },
      "conditions": {
        "states": {
          "start-automation": "OK"
        }
      },
      "predecessors": [
        "start-automation"
      ]
    },
    "start-automation": {
      "name": "start-automation",
      "input": {
        "region": "{{ input()[\"awsregion\"] }}",
        "schema": "builtin:hyperscaler-authentication.connections.aws",
        "Parameters": "{\\n  \"Service\": [\"eks\"],\\n  \"Api\": [\"AssociateIdentityProviderConfig\"],\\n  \"clusterName\": [\"{{ input()[\\\"clusterName\\\"] }}\"],\\n  \"oidcIssuerUrl\": [\"{{ input()[\\\"oidcIssuerUrl\\\"] }}\"],\\n  \"clientId\": [\"{{ input()[\\\"clientId\\\"] }}\"]\\n}",
        "connection": "{% set aws = input()[\"dynatraceawsconnection\"] %}\n{{ connection(\"builtin:hyperscaler-authentication.connections.aws\", aws) }}",
        "DocumentName": "AWS-ExecuteAwsApi"
      },
      "retry": {
        "count": 5,
        "delay": 60,
        "failedLoopIterationsOnly": true
      },
      "action": "dynatrace.aws.connector:ssm-start-automation-execution",
      "timeout": 604800,
      "position": {
        "x": 0,
        "y": 1
      },
      "predecessors": []
    }
  }
}

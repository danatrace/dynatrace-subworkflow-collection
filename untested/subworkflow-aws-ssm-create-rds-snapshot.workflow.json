{
  "title": "subworkflow - aws create rds snapshot",
  "description": "Subworkflow to create an RDS database snapshot\n\nParameters:\n\ndbInstanceId: (Required) RDS DB instance ID\nsnapshotId: (Required) Snapshot ID (must be unique)\ntagging: (Optional) Tags for the snapshot\nawsregion: (Required) AWS region\ndynatraceawsconnection: (Required) AWS OIDC connection\n\nWaits for snapshot to complete",
  "ownerType": "USER",
  "isPrivate": false,
  "schemaVersion": 3,
  "trigger": {},
  "result": "{{ result(\"check-status\") }}",
  "type": "STANDARD",
  "input": {"dbInstanceId": "my-database", "snapshotId": "my-snapshot-001", "tagging": "[]", "awsregion": "us-east-1", "dynatraceawsconnection": "awsplayground"},
  "hourlyExecutionLimit": 1000,
  "guide": "## 📸 **Create RDS Snapshot**\n\nCreates RDS snapshot via SSM.",
  "tasks": {
    "check-status": {
      "name": "check-status",
      "input": {"script": "import { execution } from '@dynatrace-sdk/automation-utils';\nexport default async function ({ execution_id }) {\n  const configGet = await fetch(`/platform/automation/v1/executions/${execution_id}/tasks/wait-for-completion/result`);\n  const configBody = await configGet.json();\n  if (configBody.AutomationExecutionStatus !== \"Success\") throw new Error(\"Snapshot creation failed!\");\n  return configBody;\n}"},
      "action": "dynatrace.automations:run-javascript",
      "timeout": 30,
      "position": {"x": 0, "y": 3},
      "conditions": {"states": {"wait-for-completion": "OK"}},
      "predecessors": ["wait-for-completion"]
    },
    "wait-for-completion": {
      "name": "wait-for-completion",
      "input": {"workflowId": "20661ec0-29d5-471f-9973-29679d5fe908", "workflowInput": "{\n  \"AutomationExecutionId\": \"{{ result(\"start-automation\").AutomationExecutionId }}\",\n  \"awsregion\": \"{{ input()[\"awsregion\"] }}\",\n  \"dynatraceawsconnection\": \"{{ input()[\"dynatraceawsconnection\"] }}\"\n}"},
      "retry": {"count": 99, "delay": 60, "failedLoopIterationsOnly": true},
      "action": "dynatrace.automations:run-workflow",
      "timeout": 604800,
      "position": {"x": 0, "y": 2},
      "conditions": {"states": {"start-automation": "OK"}},
      "predecessors": ["start-automation"]
    },
    "start-automation": {
      "name": "start-automation",
      "input": {"region": "{{ input()[\"awsregion\"] }}", "schema": "builtin:hyperscaler-authentication.connections.aws", "Parameters": "{\n  \"DBInstanceId\": [\"{{ input()[\"dbInstanceId\"] }}\"]\n}", "connection": "{% set awsconnection = input()[\"dynatraceawsconnection\"] %}\n{{ connection('builtin:hyperscaler-authentication.connections.aws', awsconnection) }}", "DocumentName": "AWS-CreateRDSSnapshot"},
      "retry": {"count": 5, "delay": 60, "failedLoopIterationsOnly": true},
      "action": "dynatrace.aws.connector:ssm-start-automation-execution",
      "timeout": 604800,
      "position": {"x": 0, "y": 1},
      "predecessors": []
    }
  }
}

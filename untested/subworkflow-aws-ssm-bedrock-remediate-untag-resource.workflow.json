{
  "title": "subworkflow - aws ssm bedrock remediate untag resource",
  "description": "Remove tags from Bedrock resources",
  "ownerType": "USER",
  "isPrivate": false,
  "schemaVersion": 3,
  "trigger": {},
  "result": "{{ result(\"check-status\") }}",
  "type": "STANDARD",
  "input": {
    "resourceArn": "arn:aws:bedrock:us-east-1:123456789012:agent/A1B2C3D4E5",
    "tagKeys": "owner,environment",
    "awsregion": "us-east-1",
    "dynatraceawsconnection": "awsplayground"
  },
  "hourlyExecutionLimit": 1000,
  "guide": "Uses AWS-ExecuteAwsApi to call bedrock-agent:UntagResource.",
  "tasks": {
    "check-status": {
      "name": "check-status",
      "input": {
        "script": "export default async function ({ execution_id }) {\\n  const r = await fetch(`/platform/automation/v1/executions/${execution_id}/tasks/wait-for-completion/result`).then(d => d.json());\\n  if (r.AutomationExecutionStatus !== \\\"Success\\\") throw new Error(\\\"Untag Bedrock resource failed\\\");\\n  return r;\\n}"
      },
      "action": "dynatrace.automations:run-javascript",
      "timeout": 30,
      "position": {
        "x": 0,
        "y": 3
      },
      "conditions": {
        "states": {
          "wait-for-completion": "OK"
        }
      },
      "predecessors": [
        "wait-for-completion"
      ]
    },
    "wait-for-completion": {
      "name": "wait-for-completion",
      "input": {
        "workflowId": "20661ec0-29d5-471f-9973-29679d5fe908",
        "workflowInput": "{\n  \"AutomationExecutionId\": \"{{ result(\"start-automation\").AutomationExecutionId }}\",\n  \"awsregion\": \"{{ input()[\"awsregion\"] }}\",\n  \"dynatraceawsconnection\": \"{{ input()[\"dynatraceawsconnection\"] }}\"\n}"
      },
      "retry": {
        "count": 99,
        "delay": 60,
        "failedLoopIterationsOnly": true
      },
      "action": "dynatrace.automations:run-workflow",
      "timeout": 604800,
      "position": {
        "x": 0,
        "y": 2
      },
      "conditions": {
        "states": {
          "start-automation": "OK"
        }
      },
      "predecessors": [
        "start-automation"
      ]
    },
    "start-automation": {
      "name": "start-automation",
      "input": {
        "region": "{{ input()[\"awsregion\"] }}",
        "schema": "builtin:hyperscaler-authentication.connections.aws",
        "Parameters": "{\\n  \"Service\": [\"bedrock-agent\"],\\n  \"Api\": [\"UntagResource\"],\\n  \"resourceArn\": [\"{{ input()[\\\"resourceArn\\\"] }}\"],\\n  \"tagKeys\": [\"{{ input()[\\\"tagKeys\\\"] }}\"]\\n}",
        "connection": "{% set aws = input()[\"dynatraceawsconnection\"] %}\n{{ connection(\"builtin:hyperscaler-authentication.connections.aws\", aws) }}",
        "DocumentName": "AWS-ExecuteAwsApi"
      },
      "retry": {
        "count": 5,
        "delay": 60,
        "failedLoopIterationsOnly": true
      },
      "action": "dynatrace.aws.connector:ssm-start-automation-execution",
      "timeout": 604800,
      "position": {
        "x": 0,
        "y": 1
      },
      "predecessors": []
    }
  }
}
